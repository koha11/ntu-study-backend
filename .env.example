# Application Configuration
NODE_ENV=development
APP_PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ntu_study
DB_SYNCHRONIZE=false
DB_LOGGING=true
# Set true only for managed Postgres (Neon, RDS, etc.). Local Postgres: false.
DB_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this
JWT_REFRESH_EXPIRATION=7d

# Google OAuth Configuration (PKCE SPA flow)
# GOOGLE_CALLBACK_URL must exactly match the SPA OAuth redirect URI (Google Console +
# frontend VITE_GOOGLE_REDIRECT_URI), e.g. http://localhost:5173/login/callback — NOT the API host.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/login/callback

# Email Configuration (MailHog for local development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=test@ntu-study.local
MAIL_PASSWORD=test
MAIL_FROM=noreply@ntu-study.local

# SPA origin for invitation links and redirects — must NOT be the API port (:3000) or redirects loop.
FRONTEND_URL=http://localhost:5173

# Canva Connect API (private integration — create at https://www.canva.dev/)
# Scopes: design:content:write, design:meta:read — redirect URI must match Developer Portal.
CANVA_CLIENT_ID=your_client_id
CANVA_CLIENT_SECRET=your_client_secret
CANVA_REDIRECT_URI=http://localhost:3000/auth/canva/callback
